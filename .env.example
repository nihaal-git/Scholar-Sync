# ── ScholarSync Environment Configuration (Example) ──
# Copy this file to .env and fill in your values.

# Groq API (required for LLM agents)
GROQ_API_KEY=your_groq_api_key_here
GROQ_API_KEYS=["key1","key2"]
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TEMPERATURE=0.1
GROQ_MAX_TOKENS=8192

# Neo4j Graph Database
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password

# ChromaDB
CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_COLLECTION_NAME=scholarsync_papers

# Embeddings
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Document Processing
CHUNK_SIZE=512
CHUNK_OVERLAP=50
MAX_PAPERS=10
UPLOAD_DIR=./data/uploads

# Validation
VALIDATION_THRESHOLD=0.7
MAX_CORRECTION_LOOPS=3

# API
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false

# Reports
REPORTS_DIR=./data/reports

# MongoDB (Chat Persistence)
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=scholarsync_db

# Firebase Auth
FIREBASE_CREDENTIALS_PATH=./firebase-service-account.json

# Local Auth (SQLite + JWT)
# Generate a secure key: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-to-a-secure-random-string
AUTH_DB_PATH=./data/auth.db
